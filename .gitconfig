[core]
	excludesfile = /Users/bensheldon/.gitignore_global
	quotepath = false
	editor = vim
[user]
	name = Ben Sheldon [he/him]
	email = bensheldon@gmail.com
	signingkey = 60B3709887216344
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[commit]
	gpgsign = true
[push]
	autoSetupRemote = true
	default = current
[init]
	defaultBranch = main
